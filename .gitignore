# pyenv
#   For a library or app, you might want to share your .python-version.
#   It makes Pyenv select the correct version of Python for this directory.
# .python-version

# pipenv
#   According to pypa/pipenv#1255, pipenv should generally have its Pinfile
#   and Pipfile.lock committed (along with the rest of the source code).
#   However, if you're working on a top-level application, you should commit Pipfile.lock.
#   If you're working on a shared library, you should not commit Pipfile.lock.
# Pipfile.lock

# poetry
#   Similar to Pipenv, poetry.lock is generally committed, but not always.
# poetry.lock

# pdm
#   Similar to Pipenv and Poetry, pdm.lock is generally committed, but not always.
# pdm.lock

# virtualenv
#   Python's virtual environments are not committed to git.
venv/
.venv/
ENV/
env/
ENV/
env.bak/
venv.bak/

